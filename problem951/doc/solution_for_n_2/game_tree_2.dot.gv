# Sequence 2: BRBR

digraph GameTree {
  node [shape=ellipse, style=filled, fillcolor=lightgray];
  node0 [label="Player 1 drew B"];
  node0 -> node1 [label="L"];
  node1 [label="Player 2 drew R"];
  node1 -> node2 [label="L"];
  node2 [label="Player 1 drew B"];
  node2 -> node3 [label="L"];
  node3 [label="Player 2 drew R"];
}
